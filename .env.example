# Local: defina UMA das opções abaixo

# Opção A — string de conexão completa
MYSQL_URL=mysql://root:senha@localhost:3306/insumos

# Opção B — variáveis separadas (o Railway preenche automaticamente)
# MYSQLHOST=localhost
# MYSQLPORT=3306
# MYSQLUSER=root
# MYSQLPASSWORD=senha
# MYSQLDATABASE=insumos

PORT=3000
